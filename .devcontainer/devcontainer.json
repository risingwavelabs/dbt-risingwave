// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-docker-compose
{
	"name": "dbt-risingwave",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspaces/dbt-risingwave",

	// 4566 = RisingWave Postgres endpoint, 5691 = RisingWave dashboard.
	"forwardPorts": [4566, 5691],

	// Install the adapter + dev/test deps and write dbt profiles once the
	// container is created. See setup.sh.
	"postCreateCommand": "bash .devcontainer/setup.sh",

	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python"
			]
		}
	},

	"remoteUser": "vscode"
}
